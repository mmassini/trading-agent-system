# Copy this file to .env and fill in your credentials.
# NEVER commit .env to version control.

# ── Alpaca (paper trading) ────────────────────────────────────────────────────
ALPACA_API_KEY=your_alpaca_api_key_here
ALPACA_SECRET_KEY=your_alpaca_secret_key_here
ALPACA_PAPER=true

# ── OANDA (practice account) — Optional, leave empty to disable forex ─────────
OANDA_ACCESS_TOKEN=
OANDA_ACCOUNT_ID=
OANDA_ENVIRONMENT=practice

# ── Anthropic / Claude ────────────────────────────────────────────────────────
ANTHROPIC_API_KEY=your_anthropic_api_key_here

# ── Sentiment sources ─────────────────────────────────────────────────────────
NEWSAPI_KEY=your_newsapi_org_key_here
TWITTER_BEARER_TOKEN=                      # Optional. Leave empty to disable.

# ── Notifications ─────────────────────────────────────────────────────────────
# Create a Telegram bot via @BotFather, then get your chat ID via @userinfobot
TELEGRAM_BOT_TOKEN=your_telegram_bot_token_here
TELEGRAM_CHAT_ID=your_telegram_chat_id_here

# ── Database ──────────────────────────────────────────────────────────────────
DB_PATH=data/trading.db
